# Database
DATABASE_URL=file:./data/leader-board.sqlite

# Upload limits
MAX_UPLOAD_BYTES=52428800

# Storage
# Use "local" for filesystem uploads or "object_store" for Volcengine TOS.
STORAGE_PROVIDER=local
UPLOAD_ROOT=./uploads

# Volcengine TOS object storage.
# Required when STORAGE_PROVIDER=object_store.
TOS_ACCESS_KEY_ID=
TOS_ACCESS_KEY_SECRET=
TOS_BUCKET=
# Example for Beijing object storage: tos-cn-beijing.volces.com
TOS_ENDPOINT=
TOS_REGION=
# Optional custom public origin, for example a CDN or bound bucket domain.
# Defaults to https://<bucket>.<endpoint>/<object-key>.
TOS_PUBLIC_BASE_URL=

# Optional short-lived security token.
TOS_STS_TOKEN=
